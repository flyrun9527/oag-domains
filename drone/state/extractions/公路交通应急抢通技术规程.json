{
  "objects": [
    {
      "name": "RoadNetworkDisasterSurvey",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "append_only",
      "summary": "路网灾情调查记录",
      "description": "通过卫星遥感、航空遥感、地面监测等手段实施的灾情快速评估记录",
      "source": "公路交通应急抢通技术规程.md§4.2.2",
      "properties": [
        {
          "name": "survey_id",
          "type": "str",
          "required": true,
          "description": "调查编号",
          "source": "§4.2.2"
        },
        {
          "name": "affected_route_count",
          "type": "int",
          "description": "受灾线路数量",
          "source": "§3.3.3"
        },
        {
          "name": "disaster_scope",
          "type": "str",
          "description": "灾情影响范围",
          "source": "§4.2.2"
        },
        {
          "name": "priority_list",
          "type": "str",
          "description": "优先抢通的生命通道、重点线路、关键节点清单",
          "source": "§3.3.4"
        }
      ]
    },
    {
      "name": "RouteDisasterSurvey",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "append_only",
      "summary": "线路灾损调查记录",
      "description": "对所属公路基础设施受损状况、结构物承载能力、抵御次生灾害能力开展的实地快速评估记录",
      "source": "公路交通应急抢通技术规程.md§3.3.5",
      "properties": [
        {
          "name": "survey_id",
          "type": "str",
          "required": true,
          "description": "调查编号",
          "source": "§3.3.5"
        },
        {
          "name": "infrastructure_id",
          "type": "str",
          "description": "受损基础设施编号",
          "source": "§3.3.5"
        },
        {
          "name": "damage_type",
          "type": "str",
          "description": "灾损类型",
          "source": "§4.4.2"
        },
        {
          "name": "damage_length",
          "type": "float",
          "description": "灾损长度",
          "source": "§4.4.2"
        },
        {
          "name": "blockage_degree",
          "type": "str",
          "description": "阻断程度",
          "source": "§4.4.2"
        },
        {
          "name": "clearance_suggestion",
          "type": "str",
          "description": "抢通建议",
          "source": "§3.3.5"
        }
      ]
    },
    {
      "name": "FacilityOnSiteInspection",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "append_only",
      "summary": "设施现场检查记录",
      "description": "对路基路面、桥涵、隧道等结构物具体灾损形态、程度、通行能力评估的核查记录",
      "source": "公路交通应急抢通技术规程.md§4.2.4",
      "properties": [
        {
          "name": "inspection_id",
          "type": "str",
          "required": true,
          "description": "检查编号",
          "source": "§4.2.4"
        },
        {
          "name": "facility_type",
          "type": "str",
          "description": "设施类型: 路基路面/桥涵/隧道",
          "source": "§4.2.4"
        },
        {
          "name": "damage_form",
          "type": "str",
          "description": "具体灾损形态",
          "source": "§4.2.4"
        },
        {
          "name": "damage_degree",
          "type": "str",
          "description": "损伤程度",
          "source": "§4.2.4"
        },
        {
          "name": "capacity_assessment",
          "type": "str",
          "description": "通行能力评估",
          "source": "§4.2.4"
        },
        {
          "name": "repair_technical_plan",
          "type": "str",
          "description": "现场应急抢修技术方案建议",
          "source": "§3.3.6"
        }
      ]
    },
    {
      "name": "EmergencyEquipment",
      "kind": "lookup_table",
      "data_source": "human_confirmed",
      "mutability": "read_only",
      "summary": "应急装备物资配置表",
      "description": "包含通用应急装备和专用应急装备的配置信息",
      "source": "公路交通应急抢通技术规程.md§9.1",
      "properties": [
        {
          "name": "equipment_id",
          "type": "str",
          "required": true,
          "description": "装备编号",
          "source": "§9.1"
        },
        {
          "name": "equipment_category",
          "type": "str",
          "description": "类别: 通用/专用",
          "source": "§9.1"
        },
        {
          "name": "application_scenario",
          "type": "str",
          "description": "应用场景",
          "source": "§9.3"
        },
        {
          "name": "capability",
          "type": "str",
          "description": "通行保障能力/技术指标",
          "source": "§9.3"
        }
      ]
    },
    {
      "name": "HighwayTrafficEmergencyEvent",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "mutable",
      "summary": "公路交通突发事件",
      "description": "公路交通突发事件",
      "source": "公路交通应急抢通技术规程.md§1.0",
      "properties": [
        {
          "name": "event_id",
          "type": "str",
          "required": true,
          "description": "事件编号",
          "source": "§1.0"
        },
        {
          "name": "status",
          "type": "str",
          "description": "状态: 发现/响应中/检查中/抢通中/已完成",
          "source": "§3.3.2"
        },
        {
          "name": "event_type",
          "type": "str",
          "description": "灾害类型",
          "source": "§3.3.2"
        }
      ],
      "status_transitions": {
        "发现": [
          "响应中"
        ],
        "响应中": [
          "检查中"
        ],
        "检查中": [
          "抢通中"
        ],
        "抢通中": [
          "已完成"
        ]
      }
    }
  ],
  "links": [
    {
      "name": "event_has_road_network_survey",
      "source": "HighwayTrafficEmergencyEvent",
      "target": "RoadNetworkDisasterSurvey",
      "join": {
        "event_id": "event_id"
      },
      "link_type": "contains",
      "cardinality": "1..1",
      "description": "突发事件触发路网灾情调查"
    },
    {
      "name": "road_network_survey_has_route_survey",
      "source": "RoadNetworkDisasterSurvey",
      "target": "RouteDisasterSurvey",
      "join": {
        "survey_id": "survey_id"
      },
      "link_type": "contains",
      "cardinality": "1..n",
      "description": "路网调查包含线路灾损调查"
    },
    {
      "name": "route_survey_has_facility_inspection",
      "source": "RouteDisasterSurvey",
      "target": "FacilityOnSiteInspection",
      "join": {
        "survey_id": "survey_id"
      },
      "link_type": "contains",
      "cardinality": "1..n",
      "description": "线路调查包含设施现场检查"
    }
  ],
  "functions": [
    {
      "name": "start_emergency_response",
      "summary": "启动应急响应",
      "description": "发现或接报灾害事件后，迅速研判灾情并启动应急响应",
      "function_type": "business",
      "group": "应急响应",
      "params": [
        {
          "name": "event_id",
          "type": "str",
          "description": "事件编号",
          "default": null
        },
        {
          "name": "initial_info",
          "type": "str",
          "description": "初步掌握的灾害类型、范围、规模等信息",
          "default": null
        }
      ],
      "writes_to": [
        "HighwayTrafficEmergencyEvent"
      ],
      "involves_objects": [
        "HighwayTrafficEmergencyEvent"
      ],
      "effects": [
        {
          "object": "HighwayTrafficEmergencyEvent",
          "field": "status",
          "set_to": "响应中"
        }
      ],
      "source": "公路交通应急抢通技术规程.md§3.3.2"
    },
    {
      "name": "conduct_facility_inspection",
      "summary": "开展设施现场检查",
      "description": "对路基路面、桥涵、隧道等结构物开展具体灾损形态、程度、通行能力评估",
      "function_type": "business",
      "group": "应急检查",
      "params": [
        {
          "name": "facility_id",
          "type": "str",
          "description": "设施ID",
          "default": null
        },
        {
          "name": "inspection_method",
          "type": "str",
          "description": "调查方式: 人工巡查/视频监控/航空遥感/卫星遥感",
          "default": null
        }
      ],
      "writes_to": [
        "FacilityOnSiteInspection"
      ],
      "involves_objects": [
        "FacilityOnSiteInspection"
      ],
      "source": "公路交通应急抢通技术规程.md§4.3"
    }
  ],
  "rules": [
    {
      "name": "infrastructure_damage_classification",
      "description": "公路基础设施损伤等级判定",
      "rule_type": "classification",
      "applies_to": [
        "FacilityOnSiteInspection"
      ],
      "result_field": "damage_degree",
      "source": "公路交通应急抢通技术规程.md§3.3.5",
      "conditions": [
        {
          "field": "damage_description",
          "operator": "eq",
          "value": "无损伤或轻微损伤",
          "result": "I"
        },
        {
          "field": "damage_description",
          "operator": "eq",
          "value": "中等损伤",
          "result": "II"
        },
        {
          "field": "damage_description",
          "operator": "eq",
          "value": "严重损伤或坍塌",
          "result": "III"
        }
      ]
    },
    {
      "name": "infrastructure_clearance_suggestion",
      "description": "根据损伤等级确定抢通建议",
      "rule_type": "classification",
      "applies_to": [
        "FacilityOnSiteInspection"
      ],
      "result_field": "clearance_suggestion",
      "source": "公路交通应急抢通技术规程.md§3.3.5",
      "conditions": [
        {
          "field": "damage_degree",
          "operator": "eq",
          "value": "I",
          "result": "观察通行"
        },
        {
          "field": "damage_degree",
          "operator": "eq",
          "value": "II",
          "result": "限制通行并加强观测"
        },
        {
          "field": "damage_degree",
          "operator": "eq",
          "value": "III",
          "result": "禁止通行并实施抢通"
        }
      ]
    }
  ],
  "workflows": [
    {
      "name": "highway_emergency_clearance_workflow",
      "description": "公路交通应急抢通全流程",
      "trigger": "发现或接报灾害事件信息",
      "involves_objects": [
        "HighwayTrafficEmergencyEvent",
        "RoadNetworkDisasterSurvey",
        "RouteDisasterSurvey",
        "FacilityOnSiteInspection"
      ],
      "steps": [
        {
          "name": "启动应急响应",
          "function": "start_emergency_response",
          "description": "研判灾情并启动响应",
          "next": "开展应急检查",
          "sla": "迅速启动"
        },
        {
          "name": "开展应急检查",
          "function": "",
          "description": "包含路网灾情调查、线路灾损调查、设施现场检查",
          "next": {
            "禁止通行并实施抢通": "现场应急抢通",
            "限制通行并加强观测": "设施现场检查",
            "观察通行": "设施现场检查"
          }
        },
        {
          "name": "现场应急抢通",
          "function": "",
          "description": "实施抢修技术方案",
          "next": "应急通行评估"
        },
        {
          "name": "应急通行评估",
          "function": "",
          "description": "评估是否满足应急通行条件",
          "next": {
            "满足条件": "开放应急通行",
            "不满足条件": "制定绕行方案"
          }
        }
      ]
    }
  ],
  "key_constraints": [
    "应按照“首报要快、续报要准、终报要全”的原则开展信息报送 (§3.3.1)",
    "应急抢通应遵循分级响应、协调联动、安全高效、永临结合的原则 (§1.0.4)",
    "应急抢通应采取现场技术监测作业安全防护措施，防范次生灾害 (§1.0.6)",
    "实施抢通施工作业前，应开展设施现场检查 (§3.3.6)"
  ],
  "_meta": {
    "doc_name": "公路交通应急抢通技术规程.md",
    "doc_type": "操作规程",
    "doc_summary": "指导公路基础设施在突发事件后的应急检查、决策及抢通实施的具体技术方法。"
  }
}