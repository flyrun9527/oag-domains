{
  "objects": [
    {
      "name": "FlightMission",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "mutable",
      "summary": "飞行活动申请及执行记录",
      "description": "飞行活动申请及执行记录，包含申请信息、审批状态、执行情况等",
      "source": "S4_CCAR-92§92.503(c)",
      "properties": [
        {
          "name": "mission_id",
          "type": "str",
          "required": true,
          "description": "飞行活动申请编号",
          "source": "§92.503(c)"
        },
        {
          "name": "status",
          "type": "str",
          "required": false,
          "description": "状态: 待审批/已批准/已拒绝/执行中/已完成/已取消",
          "source": "§92.503(c)"
        },
        {
          "name": "flight_type",
          "type": "str",
          "required": false,
          "description": "运行分类: 开放类/特定类/审定类",
          "source": "§92.7"
        },
        {
          "name": "operation_type",
          "type": "str",
          "required": false,
          "description": "运行种类: 留空飞行/航线飞行/其他飞行",
          "source": "§92.643(a)"
        },
        {
          "name": "business_type",
          "type": "str",
          "required": false,
          "description": "经营种类: 载客类/载人类/载货类/培训类/其他类",
          "source": "§92.643(b)"
        },
        {
          "name": "drone_id",
          "type": "str",
          "required": false,
          "description": "使用的无人驾驶航空器编号",
          "source": "§92.617(a)"
        },
        {
          "name": "pilot_license_id",
          "type": "str",
          "required": false,
          "description": "操控员执照编号",
          "source": "§92.51(b)"
        },
        {
          "name": "operation_certificate_id",
          "type": "str",
          "required": false,
          "description": "运营合格证编号",
          "source": "§92.603(a)"
        },
        {
          "name": "airworthiness_certificate_id",
          "type": "str",
          "required": false,
          "description": "适航证编号",
          "source": "§92.617(a)"
        },
        {
          "name": "registration_id",
          "type": "str",
          "required": false,
          "description": "实名登记号",
          "source": "§92.617(a)"
        },
        {
          "name": "flight_area",
          "type": "str",
          "required": false,
          "description": "飞行区域描述",
          "source": "§92.503(c)"
        },
        {
          "name": "flight_time",
          "type": "str",
          "required": false,
          "description": "飞行时间",
          "source": "§92.503(c)"
        },
        {
          "name": "emergency_plan",
          "type": "str",
          "required": false,
          "description": "紧急情况处置预案",
          "source": "§92.623(e)"
        }
      ],
      "status_transitions": {
        "待审批": [
          "已批准",
          "已拒绝"
        ],
        "已批准": [
          "执行中",
          "已取消"
        ],
        "执行中": [
          "已完成",
          "已取消"
        ],
        "已拒绝": [],
        "已完成": [],
        "已取消": []
      },
      "constraints": []
    },
