{
  "objects": [
    {
      "name": "RoadEmergencyEvent",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "append_only",
      "summary": "公路交通突发事件记录",
      "description": "公路交通应急抢通所针对的灾害事件，包括地震、洪水、泥石流、低温雨雪冰冻等造成的在役公路基础设施受损事件。",
      "source": "公路交通应急抢通技术规程.md§1.0.2",
      "properties": [
        {
          "name": "event_id",
          "type": "str",
          "required": true,
          "description": "事件编号",
          "source": "§3.3.2"
        },
        {
          "name": "event_type",
          "type": "str",
          "required": false,
          "description": "灾害类型：地震/洪水/泥石流/低温雨雪冰冻/其他",
          "source": "§3.1.1"
        },
        {
          "name": "event_time",
          "type": "str",
          "required": false,
          "description": "事件发生时间",
          "source": "§3.3.2"
        },
        {
          "name": "location",
          "type": "str",
          "required": false,
          "description": "受灾区域位置",
          "source": "§4.2.2"
        },
        {
          "name": "affected_road_network",
          "type": "str",
          "required": false,
          "description": "受影响路网范围",
          "source": "§4.2.2"
        },
        {
          "name": "affected_road_count",
          "type": "int",
          "required": false,
          "description": "受损线路数量",
          "source": "§3.3.3"
        },
        {
          "name": "affected_facility_count",
          "type": "int",
          "required": false,
          "description": "受损公路基础设施数量",
          "source": "§3.3.3"
        },
        {
          "name": "preliminary_info",
          "type": "str",
          "required": false,
          "description": "灾害事件初步信息",
          "source": "§3.3.2"
        },
        {
          "name": "response_level",
          "type": "str",
          "required": false,
          "description": "应急响应级别",
          "source": "§3.3.2"
        },
        {
          "name": "status",
          "type": "str",
          "required": false,
          "description": "状态：启动应急响应/应急检查中/应急抢通中/应急通行评估中/已恢复",
          "source": "§3.3.1"
        }
      ],
      "status_transitions": {
        "启动应急响应": [
          "应急检查中"
        ],
        "应急检查中": [
          "应急抢通中",
          "已恢复"
        ],
        "应急抢通中": [
          "应急通行评估中"
        ],
        "应急通行评估中": [
          "已恢复",
          "应急抢通中"
        ]
      },
      "constraints": []
    },
