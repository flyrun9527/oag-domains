        {
          "name": "mission_id",
          "type": "str",
          "required": true,
          "description": "飞行活动申请编号",
          "source": "§第二十六条"
        },
        {
          "name": "applicant",
          "type": "str",
          "required": false,
          "description": "组织飞行活动的单位或者个人",
          "source": "§第二十七条"
        },
        {
          "name": "pilot_info",
          "type": "str",
          "required": false,
          "description": "操控人员信息以及有关资质证书",
          "source": "§第二十七条"
        },
        {
          "name": "drone_type",
          "type": "str",
          "required": false,
          "description": "无人驾驶航空器的类型",
          "source": "§第二十七条"
        },
        {
          "name": "drone_quantity",
          "type": "int",
          "required": false,
          "description": "无人驾驶航空器数量",
          "source": "§第二十七条"
        },
        {
          "name": "drone_performance",
          "type": "str",
          "required": false,
          "description": "主要性能指标",
          "source": "§第二十七条"
        },
        {
          "name": "drone_registration",
          "type": "str",
          "required": false,
          "description": "登记管理信息",
          "source": "§第二十七条"
        },
        {
          "name": "mission_type",
          "type": "str",
          "required": false,
          "description": "飞行任务性质和飞行方式",
          "source": "§第二十七条"
        },
        {
          "name": "special_mission_approval",
          "type": "str",
          "required": false,
          "description": "执行国家规定的特殊通用航空飞行任务的批准文件",
          "source": "§第二十七条"
        },
        {
          "name": "takeoff_site",
          "type": "str",
          "required": false,
          "description": "起飞、降落和备降机场（场地）",
          "source": "§第二十七条"
        },
        {
          "name": "communication_method",
          "type": "str",
          "required": false,
          "description": "通信联络方法",
          "source": "§第二十七条"
        },
        {
          "name": "estimated_start_time",
          "type": "str",
          "required": false,
          "description": "预计飞行开始时刻",
          "source": "§第二十七条"
        },
        {
          "name": "estimated_end_time",
          "type": "str",
          "required": false,
          "description": "预计飞行结束时刻",
          "source": "§第二十七条"
        },
        {
          "name": "flight_route",
          "type": "str",
          "required": false,
          "description": "飞行航线、高度、速度和空域范围，进出空域方法",
          "source": "§第二十七条"
        },
        {
          "name": "control_link_frequency",
          "type": "str",
          "required": false,
          "description": "指挥控制链路无线电频率以及占用带宽",
          "source": "§第二十七条"
        },
        {
          "name": "communication_navigation_surveillance_capability",
          "type": "str",
          "required": false,
          "description": "通信、导航和被监视能力",
          "source": "§第二十七条"
        },
        {
          "name": "transponder_code",
          "type": "str",
          "required": false,
          "description": "二次雷达应答机或自动监视设备代码申请",
          "source": "§第二十七条"
        },
        {
          "name": "emergency_procedure",
          "type": "str",
          "required": false,
          "description": "应急处置程序",
          "source": "§第二十七条"
        },
        {
          "name": "special_flight_support",
          "type": "str",
          "required": false,
          "description": "特殊飞行保障需求",
          "source": "§第二十七条"
        },
        {
          "name": "approval_status",
          "type": "str",
          "required": false,
          "description": "批准状态：已批准/未批准/待审批",
          "source": "§第二十六条"
        },
        {
          "name": "approval_authority",
          "type": "str",
          "required": false,
          "description": "批准机构（空中交通管理机构）",
          "source": "§第二十八条"
        },
        {
          "name": "report_time",
          "type": "str",
          "required": false,
          "description": "计划起飞1小时前报告预计起飞时刻和准备情况",
          "source": "§第三十条"
        },
        {
          "name": "actual_start_time",
          "type": "str",
          "required": false,
          "description": "实际起飞时间",
          "source": "§第三十二条"
        },
        {
          "name": "actual_end_time",
          "type": "str",
          "required": false,
          "description": "实际结束时间",
          "source": "§第三十二条"
        },
        {
          "name": "flight_status",
          "type": "str",
          "required": false,
          "description": "飞行状态：申请中/已批准/已起飞/飞行中/已结束/异常",
          "source": "§第三十二条"
        }
      ],
      "status_transitions": {
        "申请中": [
          "已批准",
          "未批准"
        ],
        "已批准": [
          "已起飞"
        ],
        "已起飞": [
          "飞行中"
        ],
        "飞行中": [
          "已结束",
          "异常"
        ],
        "异常": [
          "已结束"
        ]
      },
      "constraints": []
    },
    {
      "name": "ControlledAirspace",
