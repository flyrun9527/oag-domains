{
  "objects": [
    {
      "name": "Drone",
      "kind": "entity",
      "data_source": "external_api",
      "mutability": "read_only",
      "summary": "无人驾驶航空器（按性能指标分类）",
      "description": "无人驾驶航空器，是指没有机载驾驶员、自备动力系统的航空器。按照性能指标分为微型、轻型、小型、中型和大型。",
      "source": "S3_无人驾驶航空器飞行管理暂行条例.md§第二条",
      "properties": [
        {
          "name": "drone_id",
          "type": "str",
          "required": true,
          "description": "无人驾驶航空器唯一标识（如产品识别码或登记号）",
          "source": "§第九条"
        },
        {
          "name": "category",
          "type": "str",
          "required": false,
          "description": "分类：微型/轻型/小型/中型/大型",
          "source": "§第二条"
        },
        {
          "name": "max_takeoff_weight_kg",
          "type": "float",
          "required": false,
          "description": "最大起飞重量（千克）",
          "source": "§第六十二条"
        },
        {
          "name": "empty_weight_kg",
          "type": "float",
          "required": false,
          "description": "空机重量（千克）",
          "source": "§第六十二条"
        },
        {
          "name": "max_flight_height_m",
          "type": "float",
          "required": false,
          "description": "最大飞行真高（米）",
          "source": "§第六十二条"
        },
        {
          "name": "max_speed_kmh",
          "type": "float",
          "required": false,
          "description": "最大平飞速度（千米/小时）",
          "source": "§第六十二条"
        },
        {
          "name": "product_identification_code",
          "type": "str",
          "required": false,
          "description": "唯一产品识别码",
          "source": "§第九条"
        },
        {
          "name": "owner",
          "type": "str",
          "required": false,
          "description": "所有者信息（实名登记）",
          "source": "§第十条"
        },
        {
          "name": "registration_status",
          "type": "str",
          "required": false,
          "description": "实名登记状态：已登记/未登记",
          "source": "§第十条"
        },
        {
          "name": "airworthiness_certificate",
          "type": "str",
          "required": false,
          "description": "适航许可（中型、大型需取得）",
          "source": "§第八条"
        },
        {
          "name": "operator_license",
          "type": "str",
          "required": false,
          "description": "运营合格证（使用除微型外的单位需取得）",
          "source": "§第十一条"
        },
        {
          "name": "pilot_license",
          "type": "str",
          "required": false,
          "description": "操控员执照（操控小型、中型、大型需取得）",
          "source": "§第十六条"
        },
        {
          "name": "insurance_status",
          "type": "str",
          "required": false,
          "description": "责任保险投保状态：已投保/未投保",
          "source": "§第十二条"
        },
        {
          "name": "airspace_keeping_capability",
          "type": "bool",
          "required": false,
          "description": "是否具备空域保持能力",
          "source": "§第六十二条"
        },
        {
          "name": "reliable_monitored_capability",
          "type": "bool",
          "required": false,
          "description": "是否具备可靠被监视能力",
          "source": "§第六十二条"
        },
        {
          "name": "radio_frequency",
          "type": "str",
          "required": false,
          "description": "指挥控制链路无线电频率",
          "source": "§第二十七条"
        }
      ],
      "status_transitions": {},
      "constraints": []
    },
    {
      "name": "FlightMission",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "mutable",
      "summary": "飞行活动申请及执行记录",
      "description": "组织无人驾驶航空器飞行活动的单位或者个人需提交的飞行活动申请，包含飞行任务、空域、时间等信息。",
      "source": "S3_无人驾驶航空器飞行管理暂行条例.md§第二十六条",
