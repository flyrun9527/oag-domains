{
  "objects": [
    {
      "name": "RoadEmergencyEvent",
      "kind": "entity",
      "data_source": "agent_generated",
      "mutability": "append_only",
      "summary": "公路交通突发事件记录",
      "description": "在自然灾害、事故等原因导致公路交通阻断情况下，需要及时抢通、恢复通行能力的紧急事件。",
      "source": "公路交通应急处置技术规范.md§2.0.1",
      "properties": [
        {
          "name": "event_id",
          "type": "str",
          "required": true,
          "description": "事件编号",
          "source": "§5.3.3"
        },
        {
          "name": "event_time",
          "type": "str",
          "required": false,
          "description": "事件发生时间",
          "source": "§5.3.3"
        },
        {
          "name": "location",
          "type": "str",
          "required": false,
          "description": "事件发生地点（路段编号、桩号等）",
          "source": "§5.3.3"
        },
        {
          "name": "event_type",
          "type": "str",
          "required": false,
          "description": "事件类型：自然灾害/事故等",
          "source": "§5.4.2"
        },
        {
          "name": "event_level",
          "type": "str",
          "required": false,
          "description": "事件级别：I级(特别重大)/II级(重大)/III级(较大)/IV级(一般)",
          "source": "§5.2.1"
        },
        {
          "name": "description",
          "type": "str",
          "required": false,
          "description": "事件起因、性质、基本过程、已造成的后果以及影响范围和事件发展趋势",
          "source": "§5.3.3"
        },
        {
          "name": "status",
          "type": "str",
          "required": false,
          "description": "事件状态：已接报/先期处置/应急响应/应急终止/总结评估",
          "source": "§5.4.1, §5.4.5, §3.0.7"
        },
        {
          "name": "reporter",
          "type": "str",
          "required": false,
          "description": "信息报送单位、联系人和联系电话",
          "source": "§5.3.3"
        },
        {
          "name": "measures_taken",
          "type": "str",
          "required": false,
          "description": "已采取的措施、下一步的工作计划",
          "source": "§5.3.3"
        }
      ],
      "status_transitions": {
        "已接报": [
          "先期处置"
        ],
        "先期处置": [
          "应急响应"
        ],
        "应急响应": [
          "应急终止"
        ],
        "应急终止": [
          "总结评估"
        ]
      },
      "constraints": []
    },
    {
      "name": "EmergencyResource",
      "kind": "entity",
