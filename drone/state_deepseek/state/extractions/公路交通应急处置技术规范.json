        },
        {
          "name": "resource_type",
          "type": "str",
          "required": false,
          "description": "资源类型：通用装备/专用装备/物资",
          "source": "§10.2.4"
        },
        {
          "name": "name",
          "type": "str",
          "required": false,
          "description": "资源名称",
          "source": "§10.2"
        },
        {
          "name": "category",
          "type": "str",
          "required": false,
          "description": "装备分类：土方装备/破碎装备/桩工装备/混凝土装备/起重吊装装备/运输装备/生存保障装备/应急侦测装备/路基路面抢通装备/桥涵抢通装备/隧道抢通装备/事故处置装备/冰雪沙泥水火灾害处置装备",
          "source": "§10.2.4"
        },
        {
          "name": "weight_class",
          "type": "str",
          "required": false,
          "description": "重量等级：微型(<1t)/轻型(1-12t)/中型(12-30t)/重型(>30t)",
          "source": "§10.2.6"
        },
        {
          "name": "deployment_mode",
          "type": "str",
          "required": false,
          "description": "部署方式：人力携行/自行运输/陆地运输/空中运输",
          "source": "§10.2.5"
        },
        {
          "name": "environment_suitability",
          "type": "str",
          "required": false,
          "description": "适用环境：全地形/高海拔/低承载/山地陡坡/高低温/常规地形",
          "source": "§10.2.7"
        },
        {
          "name": "intelligence_level",
          "type": "str",
          "required": false,
          "description": "智能化等级：等级1(非智能化)/等级2(可遥控)/等级3(环境感知)/等级4(自适应操控)",
          "source": "§10.2.8"
        },
        {
          "name": "quantity",
          "type": "int",
          "required": false,
          "description": "数量",
          "source": "§10.2"
        },
        {
          "name": "storage_location",
          "type": "str",
          "required": false,
          "description": "储备地点",
          "source": "§10.3.6"
        },
        {
          "name": "reserve_level",
          "type": "str",
          "required": false,
          "description": "储备层级：国家区域性/省级/市级/县级/公路养护队",
          "source": "§10.3.6"
        }
      ],
      "status_transitions": {},
      "constraints": []
    },
